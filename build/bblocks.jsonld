    {
      "itemIdentifier": "geonovum-labs.bbr.dcat.dcat-dataset-records",
      "name": "DCAT-Dataset/Records binding",
      "abstract": "DCAT profile of OGC API Records binds the OGC API Records schema to a DCAT Dataset. This is the baseline for semantic equivalence of OGC API records and a DCAT Dataset. This is an alternative block to the ogc-incubator version of DCAT/Records binding",
      "status": "under-development",
      "dateTimeAddition": "2026-04-08T00:00:00Z",
      "itemClass": "schema",
      "register": "geonovum-building-blocks",
      "version": "0.1",
      "dateOfLastChange": "2026-05-11",
      "link": "https://github.com/Geonovum/bblock-dcat-ap-nl",
      "dependsOn": [
        "bblocks://ogc.api.records.records-ontology",
        "bblocks://ogc.geo.geodcat.dcat",
        "bblocks://ogc.api.records.v1.schemas.recordGeoJSON"
      ],
      "sources": [
        {
          "title": "DCAT v3 Specification",
          "link": "https://www.w3.org/TR/vocab-dcat-3/"
        },
        {
          "title": "API Records Specification Repository",
          "link": "https://github.com/opengeospatial/ogcapi-records"
        }
      ],
      "scope": "dev",
      "tags": [
