    {
      "itemIdentifier": "geonovum-labs.bbr.dcat.transforms.xslt-example",
      "name": "XSLT Transforms example",
      "highlighted": true,
      "abstract": "A sample building block to showcase transforms",
      "status": "under-development",
      "dateTimeAddition": "2026-05-08T11:31:00+02:00",
      "itemClass": "schema",
      "version": "0.1",
      "dateOfLastChange": "2026-05-11",
      "shaclShapes": null,
      "schema": [
        {
          "prof:hasArtifact": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/transforms/xslt-example/schema.yaml",
          "prof:hasRole": "role:schema",
          "dct:format": "application/yaml",
          "dct:conformsTo": "https://json-schema.org/draft/2020-12/schema"
        },
        {
          "prof:hasArtifact": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/transforms/xslt-example/schema.json",
          "prof:hasRole": "role:schema",
          "dct:format": "application/json",
          "dct:conformsTo": "https://json-schema.org/draft/2020-12/schema"
        }
      ],
      "sourceSchema": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/_sources/transforms/xslt-example/schema.yaml",
      "resolvedSchemaProperties": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/transforms/xslt-example/resolvedProperties.json",
      "sourceFiles": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/_sources/transforms/xslt-example/",
      "validationPassed": true,
      "transforms": [
        {
          "id": "sample-xslt",
          "description": "This transform applies some changes to input XML to demonstrate XSLT transforms",
          "type": "xslt2",
          "ref": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/_sources/transforms/xslt-example/transforms/sample.xslt",
          "code": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<xsl:stylesheet xmlns:xsl=\"http://www.w3.org/1999/XSL/Transform\" version=\"1.0\">\n  <xsl:output method=\"xml\" indent=\"yes\" encoding=\"UTF-8\"/>\n  \n  <!-- Match the root node -->\n  <xsl:template match=\"/\">\n    <xsl:apply-templates select=\"Article\"/>\n  </xsl:template>\n  \n  <!-- Transform <Article> -->\n  <xsl:template match=\"Article\">\n    <Document type=\"article\">\n      <xsl:apply-templates select=\"*\"/>\n    </Document>\n  </xsl:template>\n  \n  <!-- Transform <Title> to <Heading> -->\n  <xsl:template match=\"Title\">\n    <Heading>\n      <xsl:apply-templates/>\n    </Heading>\n  </xsl:template>\n  \n  <!-- Wrap <Authors> content in <Contributors> -->\n  <xsl:template match=\"Authors\">\n    <Contributors>\n      <xsl:apply-templates select=\"Author\"/>\n    </Contributors>\n  </xsl:template>\n  \n  <!-- Leave <Author> as is -->\n  <xsl:template match=\"Author\">\n    <xsl:copy>\n      <xsl:apply-templates/>\n    </xsl:copy>\n  </xsl:template>\n  \n  <!-- Append \" [Modified]\" to the <Body> -->\n  <xsl:template match=\"Body\">\n    <xsl:copy>\n      <xsl:value-of select=\"concat(., ' [Modified]')\"/>\n    </xsl:copy>\n  </xsl:template>\n  \n</xsl:stylesheet>",
          "inputs": {
            "mediaTypes": [
              {
                "mimeType": "application/xml",
                "label": "XML",
                "defaultExtension": "xml"
              }
            ]
          },
          "outputs": {
            "mediaTypes": [
              {
                "mimeType": "application/xml",
                "label": "XML",
                "defaultExtension": "xml"
              }
            ]
          }
        }
      ],
      "documentation": {
        "json-full": {
          "mediatype": "application/json",
          "url": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/json-full/bbr/dcat/transforms/xslt-example/index.json"
        },
        "markdown": {
          "mediatype": "text/markdown",
          "url": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/markdown/bbr/dcat/transforms/xslt-example/index.md"
        },
        "bblocks-viewer": {
          "mediatype": "text/html",
          "url": "https://nielshoffmann.github.io/bblock-dcat-ap-nl/bblock/geonovum-labs.bbr.dcat.transforms.xslt-example"
        }
      },
      "@id": "bblocks://geonovum-labs.bbr.dcat.transforms.xslt-example",
      "@type": [
        "bblocks:Schema",
        "skos:Concept",
        "dcat:Dataset",
        "bblocks:BBlock"
      ],
      "skos:prefLabel": "XSLT Transforms example",
