<bblocks://geonovum-labs.bbr.dcat.dcat-records> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DCAT/Records binding" ;
    dct:abstract "DCAT profile of OGC API Records binds the OGC API Records schema to the DCAT vocabulary. This is the baseline for semantic equivalence of OGC API records and the DCAT model. This is an alternative block to the ogc-incubator version of DCAT/Records binding"^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-04-08T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/json-full/bbr/dcat/dcat-records/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/bblock/geonovum-labs.bbr.dcat.dcat-records> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/markdown/bbr/dcat/dcat-records/index.md> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-04-24"^^xsd:date ;
    dct:source <https://github.com/opengeospatial/ogcapi-records>,
        <https://www.w3.org/TR/vocab-dcat-3/> ;
    skos:inScheme <https://nielshoffmann.github.io/bblock-dcat-ap-nl/> ;
    skos:prefLabel "DCAT/Records binding" ;
    skos:topConceptOf <https://nielshoffmann.github.io/bblock-dcat-ap-nl/> ;
    dcat:keyword "DCAT",
        "Records",
        "profile" ;
    prof:hasResource [ dct:conformsTo <https://www.w3.org/TR/json-ld11/> ;
            dct:format "application/ld+json" ;
            prof:hasArtifact <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/dcat-records/context.jsonld> ;
            prof:hasRole role:mapping ],
        [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/dcat-records/schema.json> ;
