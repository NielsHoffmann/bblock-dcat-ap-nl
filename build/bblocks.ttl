<bblocks://geonovum-labs.bbr.dcat.dcat-dataset-records> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "DCAT-Dataset/Records binding" ;
    dct:abstract "DCAT profile of OGC API Records binds the OGC API Records schema to a DCAT Dataset. This is the baseline for semantic equivalence of OGC API records and a DCAT Dataset. This is an alternative block to the ogc-incubator version of DCAT/Records binding"^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2026-04-08T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/json-full/bbr/dcat/dcat-dataset-records/index.json> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/bblock/geonovum-labs.bbr.dcat.dcat-dataset-records> ],
        [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/generateddocs/markdown/bbr/dcat/dcat-dataset-records/index.md> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-05-08"^^xsd:date ;
    dct:source <https://github.com/opengeospatial/ogcapi-records>,
        <https://www.w3.org/TR/vocab-dcat-3/> ;
    skos:inScheme <https://nielshoffmann.github.io/bblock-dcat-ap-nl/> ;
    skos:prefLabel "DCAT-Dataset/Records binding" ;
    skos:topConceptOf <https://nielshoffmann.github.io/bblock-dcat-ap-nl/> ;
    dcat:keyword "DCAT",
        "Dataset",
        "Records",
        "profile" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
            prof:hasArtifact <https://nielshoffmann.github.io/bblock-dcat-ap-nl/build/annotated/bbr/dcat/dcat-dataset-records/schema.json> ;
            prof:hasRole role:schema ],
